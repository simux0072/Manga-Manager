# Required for host-run web, worker, migration, and CLI commands.
V2_DATABASE_URL=postgresql+psycopg://manga:manga@127.0.0.1:5432/manga_manager
V2_STORAGE_ROOT=./storage-v2

# Durable worker pools and provider-global job limits.
V2_GLOBAL_CHAPTER_CONCURRENCY=8
V2_ASURA_DOWNLOAD_CONCURRENCY=1
V2_MANGAFIRE_DOWNLOAD_CONCURRENCY=2
V2_KINGOFSHOJO_DOWNLOAD_CONCURRENCY=2
V2_ASURA_POLL_MINUTES=30
V2_MANGAFIRE_POLL_MINUTES=60
V2_KINGOFSHOJO_POLL_MINUTES=180
V2_RATE_LIMIT_COOLDOWN_MINUTES=5
V2_ASURA_RATE_LIMIT_COOLDOWN_MINUTES=15

# Download validation and shared free-space reservation.
V2_MAX_PAGE_BYTES=26214400
V2_MAX_CHAPTER_BYTES=786432000
V2_MAX_PAGES_PER_CHAPTER=2000
V2_MIN_DOWNLOAD_PAGES=3
V2_MIN_FREE_BYTES=5368709120

# Shared adapter request/page windows. Learned PostgreSQL policies can reduce them.
REQUEST_TIMEOUT_SECONDS=25
KINGOFSHOJO_TIMEOUT_SECONDS=45
ASURA_REQUEST_INTERVAL_SECONDS=2
MANGAFIRE_REQUEST_INTERVAL_SECONDS=0
KINGOFSHOJO_REQUEST_INTERVAL_SECONDS=0
ASURA_PAGE_CONCURRENCY=1
MANGAFIRE_PAGE_CONCURRENCY=4
KINGOFSHOJO_PAGE_CONCURRENCY=4
ASURA_RECENT_PAGES=3
MANGAFIRE_RECENT_PAGES=3
KINGOFSHOJO_RECENT_PAGES=3
MANGAFIRE_RECENT_LIMIT=50
MANGAFIRE_DISCOVERY_MODE=new
SOURCE_FRONTIER_REQUIRED_HITS=3
ASURA_DELAY_HOURS=6

# Automatic source scheduling.
V2_ENABLE_ASURA=true
V2_ENABLE_MANGAFIRE=true
V2_ENABLE_KINGOFSHOJO=true

# Optional Kavita integration. Docker staging provisions these automatically.
LIBRARY_ROOT=./storage-v2/library
KAVITA_URL=
KAVITA_API_KEY=
# Kavita's view of V2_STORAGE_ROOT/kavita-library (mounted read-only into Kavita).
# KAVITA_LIBRARY_ROOT=/manga
KAVITA_SERIES_URL_TEMPLATE={base_url}/library/{library_id}/series/{series_id}
KAVITA_CHAPTER_URL_TEMPLATE={base_url}/library/{library_id}/series/{series_id}/chapter/{chapter_id}
