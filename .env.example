# Local development defaults to SQLite when DATABASE_URL is unset.
# Uncomment to override local SQLite location:
# DATABASE_URL=sqlite:///./manga_manager.db
# Docker Compose defaults to Postgres when DATABASE_URL is unset.
# Uncomment only to override the Compose database:
# DATABASE_URL=postgresql+psycopg://manga:manga@postgres:5432/manga_manager
LIBRARY_ROOT=./storage/library
# Optional: set when Kavita sees LIBRARY_ROOT at a different container/mount path.
# Set this to the path where Kavita sees ./storage-v2/library. If both containers
# mount it at /data/library, leave it unset; otherwise a common Pi value is /manga.
# KAVITA_LIBRARY_ROOT=/manga
STAGING_ROOT=./storage/staging
ARCHIVE_ROOT=./storage/archive
KAVITA_URL=
KAVITA_API_KEY=
KAVITA_SYNC_WANT_TO_READ=false
KAVITA_SYNC_READ_PROGRESS=false
KAVITA_SERIES_URL_TEMPLATE={base_url}/library/{library_id}/series/{series_id}
KAVITA_CHAPTER_URL_TEMPLATE={base_url}/library/{library_id}/series/{series_id}/chapter/{chapter_id}
ENABLE_ASURA=true
ENABLE_MANGAFIRE=true
ENABLE_KINGOFSHOJO=true
ASURA_POLL_MINUTES=30
MANGAFIRE_POLL_MINUTES=60
KINGOFSHOJO_POLL_MINUTES=180
ASURA_DELAY_HOURS=6
REQUEST_TIMEOUT_SECONDS=25
MAX_PAGE_BYTES=26214400
MAX_COVER_BYTES=5242880
ASURA_REQUEST_INTERVAL_SECONDS=0
MANGAFIRE_REQUEST_INTERVAL_SECONDS=0
KINGOFSHOJO_REQUEST_INTERVAL_SECONDS=0
DOWNLOADS_ENABLED=true
DISCOVERY_PAGE_SIZE=50
FIRST_IMPORT_CHAPTERS=5
SOURCE_PULL_CONCURRENCY=4
DOWNLOAD_CONCURRENCY=2
DOWNLOAD_PER_SERIES_CONCURRENCY=1
ASURA_DOWNLOAD_CONCURRENCY=1
MANGAFIRE_DOWNLOAD_CONCURRENCY=2
KINGOFSHOJO_DOWNLOAD_CONCURRENCY=2
ASURA_PAGE_CONCURRENCY=1
MANGAFIRE_PAGE_CONCURRENCY=4
KINGOFSHOJO_PAGE_CONCURRENCY=4
BACKFILL_DOWNLOADS_ENABLED=true
MIN_PAGES_PER_CHAPTER=3
MAX_DOWNLOAD_ATTEMPTS=3
DOWNLOAD_RETRY_BASE_MINUTES=15
DOWNLOAD_STALE_MINUTES=60
RATE_LIMIT_COOLDOWN_MINUTES=30
ASURA_RATE_LIMIT_COOLDOWN_MINUTES=60
JOB_STATUS_GROUP_LIMIT=25
KEEP_REPLACED_FILES=true
RETENTION_REPLACED_DAYS=0
RETENTION_REPLACED_MAX_PER_CHAPTER=0
BASIC_AUTH_USERNAME=
BASIC_AUTH_PASSWORD=
AUTH_PROTECT_HEALTHZ=false
NOTIFICATION_WEBHOOK_URL=
NOTIFICATION_RSS_ENABLED=true
NOTIFICATION_TIMEOUT_SECONDS=5
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SOURCE_FRONTIER_SENTINELS=5
SOURCE_FRONTIER_REQUIRED_HITS=3
ASURA_RECENT_PAGES=20
KINGOFSHOJO_RECENT_PAGES=20
MANGAFIRE_RECENT_PAGES=20
MANGAFIRE_RECENT_LIMIT=50
MANGAFIRE_DISCOVERY_MODE=new
VISUAL_MATCH_ENABLED=true
VISUAL_MATCH_MAX_PAGES=6
VISUAL_MATCH_SKIP_FIRST_PAGES=2
VISUAL_MATCH_SKIP_LAST_PAGES=1
VISUAL_MATCH_SEGMENT_HEIGHT=768
VISUAL_MATCH_SEGMENT_OVERLAP=128
VISUAL_MATCH_MAX_HAMMING_DISTANCE=8
VISUAL_MATCH_MIN_SEGMENT_HITS=4
